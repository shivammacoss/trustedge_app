# ProTrader Mobile App Environment Configuration
# Copy this file to .env and update the values

# Production API URL (PTD2 Backend)
API_BASE_URL=https://api.protrader.today
API_URL=https://api.protrader.today/api/v1
WS_URL=wss://api.protrader.today

# For local development (uncomment and modify as needed):
# API_BASE_URL=http://192.168.16.234:8000
# API_URL=http://192.168.16.234:8000/api/v1
# WS_URL=ws://192.168.16.234:8000

# App Name
APP_NAME=ProTrader
